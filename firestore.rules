rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read their own customer data
    match /customers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Users can read their own subscriptions
      match /subscriptions/{subscriptionId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // Only server-side (Cloud Functions) can write
      }

      // Users can read their own resume analyses
      match /resumes/{resumeId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // Only server-side (Cloud Functions) can write
      }
    }

    // Role scores for percentile comparison — read: authenticated, write: server-only
    match /roleScores/{role} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Promo codes — authenticated read, server-only write
    match /promoCodes/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Student practice sessions — authenticated write, server-only read
    match /student_sessions/{sessionId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false; // Only Cloud Functions read these
    }

    // Institution stats — admin read, restricted to their own institution
    match /institution_stats/{institutionId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/institution_admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/institution_admins/$(request.auth.uid)).data.institutionId == institutionId;
      allow write: if false; // Only Cloud Functions write
    }

    // Institution admins — server-managed
    match /institution_admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Super admins — read own doc, write via Cloud Function only
    match /super_admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Problem reports — authenticated write, server-only read
    match /reports/{reportId} {
      allow read: if false;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
