rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read their own customer data
    match /customers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Users can read their own subscriptions
      match /subscriptions/{subscriptionId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // Only server-side (Cloud Functions) can write
      }
    }

    // Role scores for percentile comparison — read: authenticated, write: server-only
    match /roleScores/{role} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
